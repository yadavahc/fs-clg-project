rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ============================================
    // Documents Collection
    // ============================================
    match /documents/{docId} {
      // Read a single document — only the owner
      allow get: if request.auth != null && resource.data.userId == request.auth.uid;

      // List queries — authenticated users (query must filter by their own userId)
      allow list: if request.auth != null;

      // Create — must be the authenticated user's own document
      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.userId != null
        && request.resource.data.fileName != null
        && request.resource.data.fileType != null
        && request.resource.data.fileSize >= 0
        && request.resource.data.status in ['uploading', 'processing', 'completed', 'error'];

      // Update — owner only, cannot transfer ownership
      allow update: if request.auth != null
        && resource.data.userId == request.auth.uid
        && request.resource.data.userId == request.auth.uid;

      // Delete — owner only
      allow delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }

    // ============================================
    // Chat Messages Collection
    // ============================================
    match /chatMessages/{messageId} {
      allow get:  if request.auth != null && resource.data.userId == request.auth.uid;
      allow list: if request.auth != null;

      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.role in ['user', 'assistant']
        && request.resource.data.content != null
        && request.resource.data.language != null;

      allow update: if false;

      allow delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }

    // ============================================
    // User Preferences Collection
    // ============================================
    match /userPreferences/{userId} {
      allow read:   if request.auth != null && request.auth.uid == userId;
      allow write:  if request.auth != null && request.auth.uid == userId;
    }

    // ============================================
    // Deny everything else
    // ============================================
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
